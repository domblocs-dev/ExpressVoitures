@model List<Modele>

@{
    ViewData["Title"] = "Modèles";
}

<h1>Modèles</h1>

<p>
    <a asp-action="Create" asp-controller="Modeles" class="btn btn-primary">Ajouter un modèle</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Modèle</th>
            <th>Marque</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var modele in Model)
        {
            <tr>
                <td>@modele.Nom</td>
                <td>@modele.Marque.Nom</td>
                <td>
                    <a asp-action="Edit" asp-controller="Modeles" asp-route-id="@modele.Id" class="btn btn-primary btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-controller="Modeles" asp-route-id="@modele.Id" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>