@model VoitureDetailsViewModel

@{
    ViewData["Title"] = "Détails de la voiture";
    var voiture = Model.Voiture;
    var vente = voiture.Vente;
    var estVendue = vente.DateVente is not null;
}

<p>
    <a asp-controller="Home" asp-action="Index" class="ev-carac text-decoration-none">&larr; Retour</a>
</p>

<div class="row mb-5">
    <div class="col-md-6 mb-3">
        @if (!string.IsNullOrWhiteSpace(vente.PhotoUrl))
        {
            <img src="@vente.PhotoUrl" class="img-fluid"
                 alt="@voiture.Modele.Marque.Nom @voiture.Modele.Nom @voiture.Annee" />
        }
        else
        {
            <span class="ev-vignette ev-vignette-vide w-100" style="height: 320px;">Photo à venir</span>
        }
    </div>

    <div class="col-md-6">
        <p class="mb-1">Vous avez publié cette annonce, vous pouvez la :</p>
        <p>
            <a asp-controller="Voitures" asp-action="Edit" asp-route-id="@voiture.Id">modifier</a>
            <a asp-controller="Voitures" asp-action="Delete" asp-route-id="@voiture.Id" class="text-danger ms-3">supprimer</a>
        </p>

        <h1 class="mt-4">@vente.PrixVente €</h1>

        <p class="ev-carac mt-4">@voiture.Annee</p>
        <p class="ev-carac">@voiture.Modele.Marque.Nom</p>
        <p class="ev-carac">@voiture.Modele.Nom</p>
        @if (!string.IsNullOrWhiteSpace(voiture.Finition))
        {
            <p class="ev-carac">@voiture.Finition</p>
        }
        <p class="ev-carac">@vente.Statut.EnFrancais()</p>

        @if (!string.IsNullOrWhiteSpace(vente.Description))
        {
            <p class="mt-4">@vente.Description</p>
        }
    </div>
</div>

<h2>Réparations</h2>

<table class="table">
    <thead>
        <tr>
            <th>Type</th>
            <th>Coût</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reparation in vente.Reparations)
        {
            <tr>
                <td>@reparation.TypeReparation.Libelle</td>
                <td>
                    @if (estVendue)
                    {
                        <span>@reparation.Cout €</span>
                    }
                    else
                    {
                        <form asp-action="UpdateReparation" asp-controller="Voitures" method="post" class="d-flex gap-2">
                            <input type="hidden" name="reparationId" value="@reparation.Id" />
                            <input type="hidden" name="voitureId" value="@voiture.Id" />
                            <input type="number" step="0.01" name="cout" value="@reparation.Cout.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="form-control form-control-sm" style="max-width: 120px" />
                            <button type="submit" class="btn btn-secondary btn-sm">Modifier</button>
                        </form>
                    }
                </td>
                <td>
                    @if (!estVendue)
                    {
                        <form asp-action="DeleteReparation" asp-controller="Voitures" method="post">
                            <input type="hidden" name="reparationId" value="@reparation.Id" />
                            <input type="hidden" name="voitureId" value="@voiture.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (estVendue)
{
    <div class="alert alert-secondary">
        Voiture vendue : les réparations et le prix de vente sont figés, ils ne sont plus modifiables.
    </div>
}
else
{
    <h3>Ajouter une réparation</h3>
    <div class="d-flex gap-2 mt-3">
        <form asp-action="AddReparation" asp-controller="Voitures" method="post" class="m-0">
            <input type="hidden" name="voitureId" value="@voiture.Id" />
            <div class="mb-3">
                <label asp-for="TypeReparationId" class="form-label">Type de réparation</label>
                <select asp-for="TypeReparationId" asp-items="ViewBag.TypeReparationId" class="form-select">
                    <option value="">-- Choisir un type --</option>
                </select>
                <span asp-validation-for="TypeReparationId" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-ev">Ajouter la réparation</button>
        </form>
    </div>

    <div class="mt-3">
        <a asp-controller="Voitures" asp-action="Index" class="btn btn-ev-outline">Retour à l'inventaire</a>
    </div>
}