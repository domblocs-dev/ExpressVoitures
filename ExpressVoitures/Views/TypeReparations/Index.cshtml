@model List<TypeReparation>

@{
    ViewData["Title"] = "Types de réparations";
}

<h1>Types de réparations</h1>

<p>
    <a asp-action="Create" asp-controller="TypeReparations" class="btn btn-primary">Ajouter un type de réparation</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Libelle</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var typeReparation in Model)
        {
            <tr>
                <td>@typeReparation.Libelle</td>
                <td>
                    <a asp-action="Edit" asp-controller="TypeReparations" asp-route-id="@typeReparation.Id" class="btn btn-primary btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-controller="TypeReparations" asp-route-id="@typeReparation.Id" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>

</table>

