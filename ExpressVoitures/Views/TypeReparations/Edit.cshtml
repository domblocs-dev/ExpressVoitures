@model TypeReparation

@{
    ViewData["Title"] = "Modifier un type de réparation";
}

<h1>Modifier un type de réparation</h1>

<form asp-action="Edit" asp-controller="TypeReparations" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Libelle" class="form-label"></label>
        <input asp-for="Libelle" class="form-control" />
        <span asp-validation-for="Libelle" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CoutParDefaut" class="form-label">Coût par défaut</label>
        <input asp-for="CoutParDefaut" class="form-control" />
        <span asp-validation-for="CoutParDefaut" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" asp-controller="TypeReparations" class="btn btn-secondary">Annuler</a>
</form>