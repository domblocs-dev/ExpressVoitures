@model TypeReparation

@{
    ViewData["Title"] = "Supprimer un type de réparation";
}

<h1>Supprimer un type de réparation</h1>
<h3 class="text-danger">Voulez-vous vraiment supprimer ce type de réparation ?</h3>
<dl class="row">
    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Libelle)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Libelle)</dd>
</dl>
<form asp-action="Delete" asp-controller="TypeReparations" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" asp-controller="TypeReparations" class="btn btn-secondary">Annuler</a>
</form>